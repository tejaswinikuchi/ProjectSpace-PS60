        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

    // This script calls the Flow Designer API to start the Alert Flow
    try {
        var flow = sn_fd.FlowAPI.getRunner()
            .flow('x_churn_platform.churn_risk_alert_flow') // The internal name of your flow
            .inBackground(); // Runs without making the user wait

        // Define the data we are sending to the flow
        var inputs = {};
        inputs['customer_sys_id'] = current.getUniqueValue(); // Sends the specific customer's ID

        // Run the flow with the inputs
        flow.withInputs(inputs).run();
        
        gs.info("Churn Alert Flow triggered for: " + current.u_customer_id);

    } catch (ex) {
        var message = ex.getMessage();
        gs.error("Error in Business Rule 2 (Trigger Alert): " + message);
    }

})(current, previous);]]></script>
