        <script><![CDATA[(function executeRule(current, previous) {
    
    // 1. Get the score from the record (use current.u_churn_risk_score)
    var churn_risk_score = parseFloat(current.churn_risk_score);
    
    // 2. Check the score and set the category
    // NOTE: Ensure 'critical', 'high', etc., match the "Value" in your choice list (usually lowercase)
    if ( churn_risk_score>= 80) {
        current.risk_category = 'Critical';
    } else if (churn_risk_score >= 60) {
        current.risk_category = 'High';
    } else if (churn_risk_score >= 35) {
        current.risk_category = 'Medium';
    } else {
        current.risk_category = 'Low';
    }

    // 3. Debug message - this will show if the rule actually triggered
    gs.addInfoMessage("BR1 Running: Score is " + churn_risk_score + ". Setting Category to: " + current.risk_category);

})(current, previous);]]></script>
